# ===============================
# ENV FILES (NEVER COMMIT)
# ===============================
.env
.env.*
backend/.env
frontend/.env

# Example env allowed
!.env.example
!backend/.env.example
!frontend/.env.example

# ===============================
# NODE MODULES
# ===============================
node_modules/
backend/node_modules/
frontend/node_modules/

# ===============================
# BUILD OUTPUTS
# ===============================
dist/
build/
frontend/dist/
backend/dist/

# ===============================
# LOG FILES
# ===============================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===============================
# OS FILES
# ===============================
.DS_Store
Thumbs.db

# ===============================
# IDE FILES
# ===============================
.vscode/
.idea/
*.swp

# ===============================
# CACHE FILES
# ===============================
.cache/
.parcel-cache/

# ===============================
# TEMP FILES
# ===============================
tmp/
temp/

# ===============================
# DOCKER (optional if used later)
# ===============================
docker-compose.override.yml

# ===============================
# TEST COVERAGE
# ===============================
coverage/

# ===============================
