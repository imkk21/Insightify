# ─────────────────────────────────────────────
#  Insightify Backend – Environment Variables
#  Copy this file to .env and fill in your keys
# ─────────────────────────────────────────────

PORT=5000
NODE_ENV=development

# MongoDB Atlas
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/insightify?retryWrites=true&w=majority

# Firebase Admin SDK (download from Firebase Console → Project Settings → Service Accounts)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# GitHub API
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_USERNAME=your_github_username

# OpenWeather API
OPENWEATHER_API_KEY=your_openweather_api_key
DEFAULT_CITY=Ajmer

# NewsAPI
NEWS_API_KEY=your_newsapi_key

# Google Gemini AI
GEMINI_API_KEY=your_gemini_api_key

# CORS
FRONTEND_URL=http://localhost:5173
